# Example environment configuration file
# Copy this to create your own configuration files
# 
# IMPORTANT: These are example values only!
# For development, create a file with your actual credentials
# For production/GitHub Pages, use --dart-define flags during build

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Application Environment (dev, staging, prod)
APP_ENV=dev
